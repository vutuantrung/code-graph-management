{
    "name": "my-codegraph",
    "displayName": "my-codegraph",
    "description": "",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.54.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:my-codegraph.openGraph",
        "onCommand:my-codegraph.showSymbolReferences"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "my-codegraph.openGraph",
                "title": "Open Code Graph"
            },
            {
                "command": "my-codegraph.showSymbolReferences",
                "title": "Show Symbol References"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "npm run check-types && npm run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "npm run check-types && npm run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@babel/parser": "^7.29.2",
        "@types/babel__traverse": "^7.28.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.54.0",
        "@typescript-eslint/eslint-plugin": "^8.39.0",
        "@typescript-eslint/parser": "^8.39.0",
        "@vscode/test-cli": "^0.0.11",
        "@vscode/test-electron": "^2.5.2",
        "esbuild": "^0.25.8",
        "eslint": "^9.32.0",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "@babel/traverse": "^7.29.0",
        "cytoscape": "^3.33.1",
        "fast-glob": "^3.3.3"
    }
}